# Terraform working files + state. NEVER commit state or real tfvars — they
# can contain secrets and live resource attributes.
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Real variable values (the .example is committed; the real one is not).
terraform.tfvars
*.auto.tfvars
*.auto.tfvars.json

# Operator-chosen backend (kept out of git so each operator picks state location).
backend.tf

# Generated env manifest from `make bootstrap` (may echo non-secret config).
production.env.rendered
