{
  "name": "sitelayer",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web,worker \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:worker\"",
    "dev:api": "npm run dev --workspace @sitelayer/api",
    "dev:web": "npm run dev --workspace @sitelayer/web",
    "dev:worker": "npm run dev --workspace @sitelayer/worker",
    "build": "npm run build --workspace @sitelayer/domain && npm run build --workspace @sitelayer/api && npm run build --workspace @sitelayer/web && npm run build --workspace @sitelayer/worker",
    "seed:dev": "tsx apps/api/scripts/seed-dev.ts",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces",
    "format": "npm run format --workspaces"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "tsx": "^4.20.3"
  }
}
