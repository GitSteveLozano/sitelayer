# Tier marker: local|dev|preview|prod
# Authoritative env tag. Startup guard will refuse to boot on mismatch
# (e.g. APP_TIER=dev with a DATABASE_URL pointing at sitelayer_prod).
APP_TIER=local
# Production deploy persists the exact immutable registry image here.
# Local docker-compose.yml ignores this value.
APP_IMAGE=registry.digitalocean.com/sitelayer/sitelayer:main
# Optional comma-separated flags. Recognized: read-prod-ro, qbo-live,
# pdf-ocr-experimental. Ignored in prod for read-prod-ro.
FEATURE_FLAGS=
# Read-only prod pool, only consulted when FEATURE_FLAGS contains read-prod-ro.
# The user must be a read-only role (suffix _ro or contain "readonly").
DATABASE_URL_PROD_RO=

# Local API
DATABASE_URL=postgres://sitelayer:sitelayer@localhost:5432/sitelayer
# Postgres TLS. Prefer DATABASE_CA_CERT below (verified TLS) over flipping this
# to false. Set to false ONLY as a last resort for a managed Postgres URL with
# sslmode=require when no CA bundle is available — it disables cert verification.
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# PEM CA certificate (or bundle) for the managed Postgres TLS endpoint. When set,
# the pg client verifies the server cert against it (ssl.ca + rejectUnauthorized:
# true) so DATABASE_SSL_REJECT_UNAUTHORIZED=false is no longer required. Download
# from DO Console -> Databases -> sitelayer-db -> Connection Details -> Download
# CA certificate. A single-line value may use \n escapes for the PEM newlines.
# DATABASE_CA_CERT=<set-outside-git>  # -----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
PORT=3001
ACTIVE_COMPANY_SLUG=la-operations
ACTIVE_USER_ID=demo-user

# E2E fixture tenant. `npm run seed:e2e` populates the dedicated
# `e2e-fixtures` company (created by docker/postgres/init/072) with one
# ready-state row per deterministic workflow plus a membership per role
# (admin / foreman / office / member / bookkeeper). The script targets
# whichever tier `DATABASE_URL` is currently pointed at and refuses to
# run when APP_TIER=prod — intended for local + preview only, never prod.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Sentry — public DSNs are safe to commit in dev; auth token is not.
SENTRY_DSN=<sitelayer-api-public-dsn>
SENTRY_WORKER_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_SENTRY_DSN=<sitelayer-web-public-dsn>
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
# Sentry Logs (single-pane): api/worker enable `enableLogs` automatically when a
# DSN is set — every pino record (@sitelayer/logger) is mirrored into Sentry
# Logs keyed by the active trace_id, and warn/error console.* writes are captured
# too. No-op without a DSN. There is no extra env to flip this on; it follows the
# DSN guard.

# Debug trace endpoint (GET /api/debug/traces/:id)
# - Requires Bearer DEBUG_TRACE_TOKEN and APP_TIER != prod (unless DEBUG_ALLOW_PROD=1).
# - Needs SENTRY_AUTH_TOKEN (user token with event:read + project:read + org:read) and SENTRY_ORG to reach the Sentry API.
DEBUG_TRACE_TOKEN=<generate-32b-random>
SENTRY_ORG=sandolabs
SENTRY_AUTH_TOKEN=<set-outside-git>
# DEBUG_ALLOW_PROD=1  # only enable when you truly need prod trace lookups

# Structured logging (pino). default: debug in dev, info in prod.
LOG_LEVEL=debug

# Web
VITE_API_URL=http://localhost:3001
VITE_COMPANY_SLUG=la-operations
VITE_USER_ID=demo-user
VITE_APP_TIER=local

# Clerk (publishable key is safe to ship in client bundles).
# - prod:    pk_live_Y2xlcmsuc2FuZG9sYWIueHl6JA      (Frontend API: clerk.sandolab.xyz)
# - preview: pk_test_aW1wcm92ZWQtYmVkYnVnLTMwLmNsZXJrLmFjY291bnRzLmRldiQ
VITE_CLERK_PUBLISHABLE_KEY=pk_test_aW1wcm92ZWQtYmVkYnVnLTMwLmNsZXJrLmFjY291bnRzLmRldiQ
# Backend Clerk env (set on droplet, not committed):
# CLERK_JWT_KEY=<PEM public key from Clerk dashboard → JWT Public Key>
# CLERK_ISSUER=https://clerk.sandolab.xyz
# CLERK_WEBHOOK_SECRET=<svix whsec_… from Clerk dashboard → Webhooks>
# CLERK_SECRET_KEY=<clerk-backend-api-secret-key> — required by the worker's
#   notifications drain to hydrate recipient_clerk_user_id → email. Worker
#   refuses to start when this is missing unless NOTIFICATIONS_ENABLED=0.>
# AUTH_ALLOW_HEADER_FALLBACK=0  # flip after SPA Clerk rollout is verified
# AUTH_ALLOW_HEADER_FALLBACK_BREAK_GLASS=1  # prod emergency only; never leave enabled

# QBO local/sandbox placeholders
QBO_CLIENT_ID=<set-outside-git>
QBO_CLIENT_SECRET=<set-outside-git>
QBO_REDIRECT_URI=http://localhost:3001/api/integrations/qbo/callback
QBO_SUCCESS_REDIRECT_URI=http://localhost:3000/?qbo=connected
QBO_ENVIRONMENT=sandbox
QBO_BASE_URL=https://sandbox-quickbooks.api.intuit.com
QBO_LIVE_ESTIMATE_PUSH=0
QBO_LIVE_RENTAL_INVOICE=0
# Gates the labor-payroll QBO TimeActivity push in the worker. Stays at 0
# until a real QBO sandbox/prod run is validated; mirrors the other
# QBO_LIVE_* flags so the workflow plumbing exercises the stub by default.
QBO_LIVE_LABOR_PAYROLL=0
QBO_RENTAL_INCOME_ACCOUNT_ID=
QBO_STATE_SECRET=<set-outside-git>
# QBO webhook verifier token (from Intuit Developer dashboard → Webhooks).
# Used to HMAC-SHA256 verify the `intuit-signature` header on POST /api/webhooks/qbo.
QBO_WEBHOOK_VERIFIER=<set-outside-git>

# HMAC secret for public estimate share-link tokens (sales loop / client portal).
# Its OWN required prod secret — set it independently. It still falls back to
# QBO_STATE_SECRET when unset, so leaving it blank silently couples the two:
# rotating QBO_STATE_SECRET would then invalidate every customer estimate/portal
# share link. Mint with `openssl rand -base64 32` and rotate independently of QBO.
ESTIMATE_SHARE_SECRET=<set-outside-git>

# Public URL the app lives under. Used to render shareable links in `/api/projects/:id/estimate/share`
# responses ({share_url}) and the rentals customer portal. No trailing slash.
APP_PUBLIC_URL=http://localhost:3000

# Email notifications — worker drains the `notifications` table and sends via
# the chosen provider. Defaults to `console` so dev/preview never leak real mail.
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@sitelayer.sandolab.xyz
RESEND_API_KEY=
SENDGRID_API_KEY=

# Notification channels (Phase 1C) — each channel is opt-in. When any of these
# are unset the dispatcher's fallback ladder kicks in (chosen → email → defer).
# A user can also opt out per event-type via PUT /api/notification-preferences.
#
# Web Push (PWA assignment alerts, foreman pings, anomaly notices). Generate
# the keypair with:    npx web-push generate-vapid-keys
# Subject is a contact mailto: or https URL Mozilla's push service can reach.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@sitelayer.sandolab.xyz
#
# Twilio SMS (workers without the PWA installed; assignment confirms via
# one-click reply). Use a Programmable Messaging trial number for dev/preview.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# API rate limiting — token bucket per authenticated user / per IP for /api/*.
# /health and /api/webhooks/* are exempt. Window is fixed at 60s.
RATE_LIMIT_PER_USER_PER_MIN=100
RATE_LIMIT_PER_IP_PER_MIN=30
# Aggregate per-tenant cap (a second, independent bucket on top of per-user) so
# one noisy company can't starve the shared API. Sized high relative to per-user.
RATE_LIMIT_PER_COMPANY_PER_MIN=1000
# Per-share-token caps for the public /api/portal/* surface (which is EXEMPT
# from the per-user/per-IP buckets above — a NAT-shared customer would otherwise
# collide with internal callers). READ = GET the portal view (generous); WRITE =
# state-changing POSTs (accept/decline/finalize + capture lifecycle; tight). Both
# are per single share token, so a flood on one token never throttles another
# customer, and a legitimate single customer stays well under the cap.
RATE_LIMIT_PER_PORTAL_TOKEN_READ_PER_MIN=60
RATE_LIMIT_PER_PORTAL_TOKEN_WRITE_PER_MIN=20

# Postgres pool circuit breaker.
# - PG_POOL_MAX bounds connection count so a slow-query storm can't exhaust PG.
# - PG_STATEMENT_TIMEOUT_MS / PG_QUERY_TIMEOUT_MS fail individual queries fast.
# - PG_HEALTH_PROBE_TIMEOUT_MS caps the /health DB probe so the endpoint stays
#   reachable when the pool is wedged (returns 503 with db.db="timeout").
PG_POOL_MAX=20
PG_STATEMENT_TIMEOUT_MS=5000
PG_QUERY_TIMEOUT_MS=10000
PG_HEALTH_PROBE_TIMEOUT_MS=1500
# Close idle pg backends after this long. Stops managed-Postgres connection-hour
# bills from accumulating on backends that sit around between heartbeats.
PG_IDLE_TIMEOUT_MS=30000

# HTTP-layer timeouts on the Node http server. Defaults are deliberately wider
# than PG_QUERY_TIMEOUT_MS so a legit slow query is not killed mid-flight.
# - HTTP_REQUEST_TIMEOUT_MS: per-request socket deadline. MUST exceed
#   PG_QUERY_TIMEOUT_MS.
# - HTTP_HEADERS_TIMEOUT_MS: how long the client has to finish sending headers.
# - HTTP_KEEP_ALIVE_TIMEOUT_MS: idle keep-alive close. Short by default so
#   load balancers / health probes do not park sockets on the API.
HTTP_REQUEST_TIMEOUT_MS=30000
HTTP_HEADERS_TIMEOUT_MS=60000
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000

# How long an applied mutation_outbox / sync_events row sticks around before the
# daily queue-prune runner deletes it. Defaults to 90 days; lower in dev/preview.
QUEUE_APPLIED_RETENTION_DAYS=90

# Request body size cap (bytes) for JSON requests. Blueprint uploads now go
# through the streaming multipart path (see MAX_BLUEPRINT_UPLOAD_BYTES) and no
# longer fight this limit; only legacy base64 fallback uploads still flow here.
MAX_JSON_BODY_BYTES=20971520

# Per-blueprint upload size cap for the streaming multipart path. Construction
# PDFs typically run 30–80MB; default leaves headroom for large multi-sheet sets.
MAX_BLUEPRINT_UPLOAD_BYTES=209715200

# Set to 1 to redirect blueprint downloads to a 15-minute presigned Spaces URL
# instead of streaming bytes through the API. Requires Spaces CORS configured
# for the SPA origin; leave unset until validated. OFF by default: when unset
# the API streams bytes itself so no Spaces URL leaks (blueprints are untrusted
# PII blobs — see docs/BLUEPRINT_SECURITY.md).
BLUEPRINT_DOWNLOAD_PRESIGNED=

# OPT-IN blueprint PII scan (1/true/on/yes). Default OFF and currently a no-op
# stub — sitelayer does not scan/redact blueprint PII today; RLS + access
# control are the protection. Reserved seam for a future PII-detection hook;
# flipping it on changes nothing until that scan ships. See
# docs/BLUEPRINT_SECURITY.md and apps/api/src/blueprint-pii-scan.ts.
BLUEPRINT_PII_SCAN=

# Bearer token gating /api/metrics for Prometheus scrape.
API_METRICS_TOKEN=<generate-32b-random>

# Optional service-to-service bearer (alternative to Clerk JWT). Currently
# unused; reserved for inter-service traffic if/when introduced.
INTERNAL_AUTH_TOKEN=

# Blueprint storage. The API auto-selects S3Storage when DO_SPACES_BUCKET +
# DO_SPACES_KEY + DO_SPACES_SECRET are all set; otherwise local FS fallback
# at BLUEPRINT_STORAGE_ROOT (Docker volume in compose).
BLUEPRINT_STORAGE_ROOT=/app/storage/blueprints
# Prod escape hatch only while Spaces credentials are blank. Requires
# sitelayer-blueprint-backup.timer or equivalent off-host backup coverage.
ALLOW_LOCAL_BLUEPRINT_STORAGE_IN_PROD=
DO_SPACES_BUCKET=
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=tor1
DO_SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com

# Off-region prod Postgres backup target (scripts/backup-to-offregion.sh +
# sitelayer-offregion-backup.timer). All other backup layers (managed PG
# PITR, droplet snapshot, daily logical dump + off-host copy) live in tor1,
# so a region-wide DO outage means slow manual rebuild. These vars point
# the daily 06:00 UTC dump at a bucket in a different region (e.g. nyc3).
# Script refuses to run when any of these are unset; configure all four
# before enabling sitelayer-offregion-backup.timer on the prod droplet.
DO_SPACES_OFFREGION_KEY=<scoped-spaces-key-for-offregion-bucket>
DO_SPACES_OFFREGION_SECRET=<scoped-spaces-secret-for-offregion-bucket>
DO_SPACES_OFFREGION_BUCKET=sitelayer-backups-nyc3
DO_SPACES_OFFREGION_ENDPOINT=https://nyc3.digitaloceanspaces.com

# Blueprint vision (Claude Opus PDF takeoff). The capture dispatcher
# (`POST /api/projects/:id/takeoff-drafts/capture` with kind=blueprint_vision)
# stays in dry-run stub mode by default. Set BLUEPRINT_VISION_MODE=live AND
# provide a real ANTHROPIC_API_KEY to enable the live path; any other
# combination falls back to the deterministic stub so an unset key never
# burns Anthropic credit accidentally. Live mode requires the multipart
# upload form of the endpoint (one `blueprint_file` part); the JSON body
# form is still accepted for backfills/dry-run probes.
BLUEPRINT_VISION_MODE=dry-run
ANTHROPIC_API_KEY=<set-outside-git>

# Luma 3D Capture API key — backs the `packages/pipe-photogrammetry` Path A
# pipeline (phone video → Luma job → review-required TakeoffResult). Required
# for live photogrammetry capture; without it the CLI/library throws.
LUMA_API_KEY=<set-outside-git>

# NodeODM sidecar URL — backs the `packages/pipe-drone` Path A pipeline
# (drone imagery → NodeODM reconstruction). Format: http://host:3000.
# Required for live drone capture; without it the CLI exits immediately.
NODEODM_URL=<set-outside-git>

# Field-event photo/voice upload caps (bytes). Worker-issue attachments are
# voice notes + photos; daily-log photos are scope-step site photos. Override
# either when a customer needs larger media; default leaves headroom for
# typical site photos without blowing through the multipart streaming path.
MAX_WORKER_ISSUE_ATTACHMENT_BYTES=26214400
MAX_DAILY_LOG_PHOTO_BYTES=15728640

# Worker tuning. The worker polls mutation_outbox + sync_events at this
# interval and drains the notifications table in batches. When a tick
# finds no work across any runner the scheduler doubles the next
# interval up to WORKER_POLL_MAX_INTERVAL_MS; the first tick that finds
# work resets back to WORKER_POLL_INTERVAL_MS. This cuts empty-queue
# scans roughly 6x without sacrificing reaction time on a fresh outbox
# row (worst case = max-interval-ms latency before the next poll).
WORKER_POLL_INTERVAL_MS=10000
WORKER_POLL_MAX_INTERVAL_MS=60000
# Optional external-uptime heartbeat. When set, the worker fires a
# fire-and-forget GET to this URL at the end of every drain loop iteration so an
# uptime monitor (healthchecks.io, Better Uptime, etc.) can detect a stalled or
# crashed worker. Errors are swallowed; unset = disabled.
WORKER_HEARTBEAT_URL=
NOTIFICATION_BATCH_LIMIT=50
NOTIFICATION_MAX_ATTEMPTS=5
# Gates the worker notification drain. Defaults to enabled (1); set to 0 to
# skip the drain entirely (also disables the CLERK_SECRET_KEY startup check).
# Leave at default in prod.
NOTIFICATIONS_ENABLED=1
# Clerk user→email cache TTL for the drain (default 5m).
# CLERK_EMAIL_CACHE_TTL_MS=300000
SHUTDOWN_TIMEOUT_MS=15000

# ---- Control-plane / mesh integration (OPTIONAL — unset = control-plane-disconnected) ----
#
# Sitelayer talks to the operator's control-plane/mesh stack over plain HTTP +
# HMAC. EVERY knob below is opt-in and off by default. A build with none of
# these set is fully functional but control-plane-disconnected, which surfaces
# as exactly three (intentional, non-fatal) behaviors:
#   - AI chat (POST /api/ai/chat) is feature-gated OFF: with MESH_API_URL
#     unset (and no AI_CHAT_ENABLED=1 override) the route returns a calm
#     200 {"status":"disabled"} and the web widget hides its composer — no
#     staged message, no error noise. See the AI_CHAT_ENABLED gate below.
#   - /work dispatch (POST /api/work-requests/* agent-routable paths) returns
#     503 "projectkit dispatch is not configured" and the worker's context-work
#     dispatch runner no-ops.
#   - Trace + observation forwarding silently no-ops (best-effort by design:
#     the forwarders return a "not configured" reason and never bubble an
#     error, so invoicing / QBO sync are never blocked by a dead operator
#     stack). See apps/worker/src/runners/mesh-trace-forward.ts and
#     apps/worker/src/mesh-observation-client.ts.
#
# HMAC secrets are minted in mesh (component_auth_secrets). Under the
# local-fleet deploy model, values are rendered into `/app/sitelayer/.env` on
# the prod droplet (scripts/render-production-env.mjs ← ops/env/production.env.json,
# reading the fleet operator's environment) — never committed. See
# docs/SECRET_ROTATION.md. Names only here.

# -- Trace forward (workflow_event_log + capture-session events → mesh product-trace ingest) --
# apps/worker/src/runners/mesh-trace-forward.ts. Off unless URL + COMPONENT +
# SECRET are ALL set; then a standalone interval loop ships low-PII typed flow
# shape (workflow_name/state/outcome/state_version), never event payloads.
# Full product-trace ingest URL on the mesh/operator gateway.
MESH_TRACE_FORWARD_URL=
# Component name registered in mesh component_auth_secrets for HMAC auth.
MESH_TRACE_HMAC_COMPONENT=
# Hex-encoded HMAC secret bytes for the above component (set outside git).
MESH_TRACE_HMAC_SECRET=
# Project key stamped on forwarded traces (default "sitelayer").
MESH_TRACE_PROJECT_KEY=
# Forwarder tick interval in ms (default 60000).
MESH_TRACE_FORWARD_INTERVAL_MS=
# Overlapping look-back window per tick in minutes (default 10).
MESH_TRACE_FORWARD_WINDOW_MIN=
# Hard per-POST abort ceiling in ms so a hung gateway can't park a socket
# (default 8000).
MESH_TRACE_FORWARD_TIMEOUT_MS=

# -- Observation forward (work-item status transitions → mesh /api/observations/ingest) --
# apps/worker/src/mesh-observation-client.ts. Off unless all three are set;
# best-effort HMAC POST (canonical "<ts>.<METHOD>.<path>.<sha256(body)>").
# Full mesh observation ingest URL (must include a path component).
MESH_OBSERVATION_INGRESS_URL=
# Component name registered in mesh component_auth_secrets (e.g. sitelayer-worker).
MESH_OBSERVATION_COMPONENT=
# Hex-encoded secret bytes for the observation component (set outside git).
MESH_OBSERVATION_SECRET_HEX=

# -- Operator chat dispatch (POST /api/ai/chat → mesh task → CLI runner webhook) --
# apps/api/src/mesh-dispatcher.ts. BOTH MESH_API_URL and SITELAYER_PUBLIC_BASE
# are required for the chat hand-off to mesh.
#
# FEATURE GATE (isAiChatEnabled() in apps/api/src/mesh-dispatcher.ts): the
# in-app operator AI chat is a SINGLE flag.
#   - AI_CHAT_ENABLED is the explicit override: 0/false/off/no forces it OFF
#     (even with MESH_API_URL set); 1/true/on/yes forces it ON.
#   - Unset AI_CHAT_ENABLED ⇒ a non-empty MESH_API_URL is the implicit enable
#     signal (preserves the operator's own deployment, which sets it).
# When the chat is DISABLED, POST /api/ai/chat answers a calm, structured
# 200 {"status":"disabled","ai_chat_enabled":false} — NO staged audit row,
# NO mesh dispatch, NO repeated 503/error logs — and the web widget hides
# its composer (it reads ai_chat_enabled off GET /api/features). A fresh
# owner with no mesh access gets a clean app, not error noise. Leave unset
# (and MESH_API_URL unset) to keep the chat off.
AI_CHAT_ENABLED=
# Base URL of the mesh API (the dispatcher POSTs <MESH_API_URL>/api/tasks).
# Also used by /api/work-requests to build the mesh task cancel URL.
# Reachable ONLY inside the operator's Tailnet (e.g. http://mesh-hetzner:8713);
# a deployment without Tailnet access leaves this unset → AI chat disabled.
MESH_API_URL=
# Public base URL the CLI runner uses to call back into Sitelayer
# (webhook POST /api/ai/chat/:id/respond, work-request callbacks). No trailing
# slash. Falls back to PUBLIC_BASE_URL / APP_PUBLIC_BASE_URL for work-request
# callbacks only; the chat dispatcher requires SITELAYER_PUBLIC_BASE explicitly.
SITELAYER_PUBLIC_BASE=
# Bearer token the CLI runner presents on the chat-respond webhook
# (apps/api/src/routes/ai-chat.ts). Unset = webhook returns 503 "webhook
# disabled". Set outside git.
SITELAYER_CHAT_WEBHOOK_TOKEN=
# Bearer token the CLI runner presents on the voice-intent respond webhook
# (apps/api/src/routes/voice-intent.ts → POST /api/projects/voice-intent/:id/respond).
# Voice-driven project setup (v1): voice PROPOSES proposed project fields parsed
# via the SAME mesh hand-off the chat uses (gated by the same isAiChatEnabled()
# flag — AI_CHAT_ENABLED / MESH_API_URL). The web stages a transcript, the mesh
# CLI runner posts the parsed JSON back here, and the new-project form pre-fills.
# Voice NEVER creates a project — the human reviews + taps Create (POST
# /api/projects). Unset = webhook returns 503 "webhook disabled". Set outside git.
SITELAYER_VOICE_INTENT_WEBHOOK_TOKEN=

# -- Work-request dispatch (context_work_items → projectkit dispatch adapter) --
# apps/worker/src/runners/context-work-dispatch.ts + apps/api/src/routes/work-requests.ts.
# Worker target the dispatch_mesh_work_request outbox rows POST to. Mesh is one
# compatible adapter behind this URL, not the producer contract. Unset = the
# API's agent-routable work-request paths return 503 and the worker runner no-ops.
PROJECTKIT_WORK_REQUEST_DISPATCH_URL=
# Bearer token for the dispatch POST. Falls back to the legacy mesh token names
# below while deployments migrate.
PROJECTKIT_WORK_REQUEST_DISPATCH_TOKEN=
# Legacy fallback URL/token names for the Mesh dispatch adapter. Keep supported
# until deployed envs migrate to PROJECTKIT_*.
MESH_WORK_REQUEST_DISPATCH_URL=
MESH_WORK_REQUEST_DISPATCH_TOKEN=
# Generic mesh API bearer, used as the dispatch-token fallback. Set outside git.
MESH_API_TOKEN=
# Legacy fallback Bearer token for /api/work-requests/:id/agent-callback rows
# created before per-dispatch scoped tokens. Set outside git.
SITELAYER_WORK_REQUEST_WEBHOOK_TOKEN=
# Hours before a scoped work-request callback token expires (default 72, clamped 1–720).
WORK_REQUEST_CALLBACK_TOKEN_TTL_HOURS=
# Work item stale/reconciliation thresholds. The callback reconciler runs before
# the generic stale sweep and writes agent.callback_missing when an acknowledged
# Mesh dispatch never posts back.
WORK_REQUEST_REVIEW_STALE_HOURS=
WORK_REQUEST_AGENT_STALE_HOURS=
WORK_REQUEST_STALE_SWEEP_INTERVAL_MS=
WORK_REQUEST_STALE_SWEEP_LIMIT=
WORK_REQUEST_CALLBACK_MISSING_HOURS=
WORK_REQUEST_CALLBACK_RECONCILE_INTERVAL_MS=
WORK_REQUEST_CALLBACK_RECONCILE_LIMIT=
# Backpressure guards: skip dispatch when pending/failed dispatch rows exceed
# these counts (defaults 100 / 50, each clamped 1–1000).
WORK_REQUEST_DISPATCH_MAX_PENDING=
WORK_REQUEST_DISPATCH_MAX_FAILED=

# -- Capture auto-dispatch bridges (capture → context_work_item → mesh) --
# Each is a default-OFF "1"-gated bridge; flipping one auto-routes captured
# work into the dispatch outbox (still inert unless PROJECTKIT_WORK_REQUEST_DISPATCH_URL
# or its legacy MESH_WORK_REQUEST_DISPATCH_URL fallback is also set).
# apps/worker/src/runners/context-work-dispatch.ts (gate, default on once a
# dispatch URL exists; set "0" to disable, "1" to force).
CONTEXT_WORK_DISPATCH_AUTO_DISPATCH=
# apps/api/src/routes/capture-sessions.ts — auto-dispatch trusted authenticated
# triage captures. "1" enables.
CAPTURE_AUTH_AUTO_DISPATCH=
# apps/worker/src/runners/capture-artifact-analysis.ts — auto-dispatch a work
# item once artifact analysis is ready. "1" enables.
CAPTURE_ARTIFACT_ANALYSIS_AUTO_DISPATCH=

# -- Agent feed (the @operator/projectkit pull-executor producer surface) --
# apps/api/src/routes/agent-feed.ts. Bearer tokens for the machine clients that
# poll /api/agent-feed/* — a JSON map of audience -> token, e.g.
# {"capture-analyzer":"<token>","steve":"<token>"}. Each token only grants its
# own audience. UNSET = every /api/agent-feed/* route answers 503 (feed off,
# fail loud not open). Names only here; real values live in the droplet .env.
AGENT_FEED_TOKENS=
# apps/api/src/routes/ops-diagnostics.ts. Optional Mobile Ops onsite diagnostic
# action routing. Unset = session actions are recorded audit-only. When set,
# value must match an AGENT_FEED_TOKENS JSON key and the executor's
# PULL_AUDIENCE.
SITELAYER_OPS_DIAGNOSTIC_AGENT_AUDIENCE=
# apps/api/src/routes/capture-sessions.ts — enqueue an audience
# 'capture-analyzer' Concern (concern_ref capan:<capture_session_id>) into
# agent_feed_concerns at finalize. "1" enables; default OFF.
AGENT_FEED_CAPTURE_ANALYZER=
# Capture artifact analysis. Text/json summaries run deterministically. Raw
# audio analysis posts bytes to a Whisper-compatible /transcribe endpoint; set
# CAPTURE_ARTIFACT_WHISPER_PAYLOAD_MODE=path only when the worker and Whisper
# server share a filesystem namespace.
MAX_CAPTURE_ARTIFACT_BYTES=
CAPTURE_ARTIFACT_ANALYSIS_INTERVAL_MS=
CAPTURE_ARTIFACT_ANALYSIS_LIMIT=
CAPTURE_ARTIFACT_ANALYSIS_MAX_BYTES=
CAPTURE_ARTIFACT_AUDIO_ANALYSIS_MODE=off
CAPTURE_ARTIFACT_WHISPER_URL=http://127.0.0.1:5678
CAPTURE_ARTIFACT_WHISPER_PAYLOAD_MODE=base64
CAPTURE_ARTIFACT_WHISPER_TIMEOUT_MS=10000
CAPTURE_ARTIFACT_WHISPER_UNAVAILABLE_POLICY=retry
CAPTURE_ARTIFACT_VIDEO_ANALYSIS_MODE=off
# Local workstation media-understanding worker. Droplet workers should normally
# leave this off; `npm run capture:media-worker` defaults to llama-swap locally.
MEDIA_UNDERSTANDING_ENGINE=off
MEDIA_UNDERSTANDING_LLAMASWAP_URL=http://127.0.0.1:8081/v1
MEDIA_UNDERSTANDING_LLAMASWAP_MODEL=gemma4-12b-vision
MEDIA_UNDERSTANDING_LLAMASWAP_MAX_FRAMES=8
MEDIA_UNDERSTANDING_LLAMASWAP_TIMEOUT_MS=120000
MEDIA_UNDERSTANDING_LLAMASWAP_MAX_TOKENS=800
# Demo-tier portal origin allowed to call capture/portal endpoints. Only
# meaningful when APP_TIER=demo; defaults to the portal base URL when unset
# (apps/api/src/server.ts).
DEMO_APP_ORIGIN=

# -- DB-verify proof gates (smoke/verification only — NOT read at runtime) --
# Used exclusively by scripts/dispatch-capture-session-smoke.ts and
# scripts/trace-capture-session-smoke.ts to prove a dispatch/trace row actually
# landed in the Control Plane database end-to-end. Leave unset for normal
# deploys; set per-invocation when running the smokes against a real mesh.
# Refuse-real-endpoint safety latches (must be "1" to hit a real CP endpoint
# instead of the local fake):
ALLOW_REAL_MESH_DISPATCH_SMOKE=
ALLOW_REAL_MESH_TRACE_SMOKE=
# Set "1" to FAIL the smoke when the Control Plane DB row can't be verified:
REQUIRE_MESH_DISPATCH_DB_VERIFY=
REQUIRE_MESH_TRACE_DB_VERIFY=
# Set "1" to FAIL the trace smoke --preflight when a CP prerequisite is missing:
REQUIRE_MESH_TRACE_PREFLIGHT=
# Control Plane Postgres DSN the smokes connect to for row verification
# (MESH_POSTGRES_DSN is checked first, then CONTROL_PLANE_POSTGRES_DSN). Set
# outside git; never a sitelayer DSN.
MESH_POSTGRES_DSN=
CONTROL_PLANE_POSTGRES_DSN=
# Per-query timeout (ms) for the CP DB verification step (default 5000 each).
MESH_DISPATCH_DB_VERIFY_TIMEOUT_MS=
MESH_TRACE_DB_VERIFY_TIMEOUT_MS=
