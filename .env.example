# Tier marker: local|dev|preview|prod
# Authoritative env tag. Startup guard will refuse to boot on mismatch
# (e.g. APP_TIER=dev with a DATABASE_URL pointing at sitelayer_prod).
APP_TIER=local
# Production deploy persists the exact immutable registry image here.
# Local docker-compose.yml ignores this value.
APP_IMAGE=registry.digitalocean.com/sitelayer/sitelayer:main
# Optional comma-separated flags. Recognized: read-prod-ro, qbo-live,
# pdf-ocr-experimental. Ignored in prod for read-prod-ro.
FEATURE_FLAGS=
# Read-only prod pool, only consulted when FEATURE_FLAGS contains read-prod-ro.
# The user must be a read-only role (suffix _ro or contain "readonly").
DATABASE_URL_PROD_RO=

# Local API
DATABASE_URL=postgres://sitelayer:sitelayer@localhost:5432/sitelayer
# Set to false for DigitalOcean managed Postgres URLs that use sslmode=require
# until a CA bundle is configured in the Node runtime.
DATABASE_SSL_REJECT_UNAUTHORIZED=true
PORT=3001
ACTIVE_COMPANY_SLUG=la-operations
ACTIVE_USER_ID=demo-user
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Sentry — public DSNs are safe to commit in dev; auth token is not.
SENTRY_DSN=<sitelayer-api-public-dsn>
SENTRY_WORKER_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_SENTRY_DSN=<sitelayer-web-public-dsn>
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Debug trace endpoint (GET /api/debug/traces/:id)
# - Requires Bearer DEBUG_TRACE_TOKEN and APP_TIER != prod (unless DEBUG_ALLOW_PROD=1).
# - Needs SENTRY_AUTH_TOKEN (user token with event:read + project:read + org:read) and SENTRY_ORG to reach the Sentry API.
DEBUG_TRACE_TOKEN=<generate-32b-random>
SENTRY_ORG=sandolabs
SENTRY_AUTH_TOKEN=<set-outside-git>
# DEBUG_ALLOW_PROD=1  # only enable when you truly need prod trace lookups

# Structured logging (pino). default: debug in dev, info in prod.
LOG_LEVEL=debug

# Web
VITE_API_URL=http://localhost:3001
VITE_COMPANY_SLUG=la-operations
VITE_USER_ID=demo-user
VITE_APP_TIER=local

# Clerk (publishable key is safe to ship in client bundles).
# - prod:    pk_live_Y2xlcmsuc2FuZG9sYWIueHl6JA      (Frontend API: clerk.sandolab.xyz)
# - preview: pk_test_aW1wcm92ZWQtYmVkYnVnLTMwLmNsZXJrLmFjY291bnRzLmRldiQ
VITE_CLERK_PUBLISHABLE_KEY=pk_test_aW1wcm92ZWQtYmVkYnVnLTMwLmNsZXJrLmFjY291bnRzLmRldiQ
# Backend Clerk env (set on droplet, not committed):
# CLERK_JWT_KEY=<PEM public key from Clerk dashboard → JWT Public Key>
# CLERK_ISSUER=https://clerk.sandolab.xyz
# CLERK_WEBHOOK_SECRET=<svix whsec_… from Clerk dashboard → Webhooks>
# AUTH_ALLOW_HEADER_FALLBACK=0  # flip after SPA Clerk rollout is verified
# AUTH_ALLOW_HEADER_FALLBACK_BREAK_GLASS=1  # prod emergency only; never leave enabled

# QBO local/sandbox placeholders
QBO_CLIENT_ID=<set-outside-git>
QBO_CLIENT_SECRET=<set-outside-git>
QBO_REDIRECT_URI=http://localhost:3001/api/integrations/qbo/callback
QBO_SUCCESS_REDIRECT_URI=http://localhost:3000/?qbo=connected
QBO_ENVIRONMENT=sandbox
QBO_STATE_SECRET=<set-outside-git>
# QBO webhook verifier token (from Intuit Developer dashboard → Webhooks).
# Used to HMAC-SHA256 verify the `intuit-signature` header on POST /api/webhooks/qbo.
QBO_WEBHOOK_VERIFIER=<set-outside-git>

# Email notifications — worker drains the `notifications` table and sends via
# the chosen provider. Defaults to `console` so dev/preview never leak real mail.
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@sitelayer.sandolab.xyz
RESEND_API_KEY=
SENDGRID_API_KEY=

# API rate limiting — token bucket per authenticated user / per IP for /api/*.
# /health and /api/webhooks/* are exempt. Window is fixed at 60s.
RATE_LIMIT_PER_USER_PER_MIN=100
RATE_LIMIT_PER_IP_PER_MIN=30

# Postgres pool circuit breaker.
# - PG_POOL_MAX bounds connection count so a slow-query storm can't exhaust PG.
# - PG_STATEMENT_TIMEOUT_MS / PG_QUERY_TIMEOUT_MS fail individual queries fast.
# - PG_HEALTH_PROBE_TIMEOUT_MS caps the /health DB probe so the endpoint stays
#   reachable when the pool is wedged (returns 503 with db.db="timeout").
PG_POOL_MAX=20
PG_STATEMENT_TIMEOUT_MS=5000
PG_QUERY_TIMEOUT_MS=10000
PG_HEALTH_PROBE_TIMEOUT_MS=1500

# Request body size cap (bytes) for the API. Blueprints upload as base64 JSON
# today; bump this if you need to accept >20MB until streaming upload ships.
MAX_JSON_BODY_BYTES=20971520

# Bearer token gating /api/metrics for Prometheus scrape.
API_METRICS_TOKEN=<generate-32b-random>

# Optional service-to-service bearer (alternative to Clerk JWT). Currently
# unused; reserved for inter-service traffic if/when introduced.
INTERNAL_AUTH_TOKEN=

# Blueprint storage. The API auto-selects S3Storage when DO_SPACES_BUCKET +
# DO_SPACES_KEY + DO_SPACES_SECRET are all set; otherwise local FS fallback
# at BLUEPRINT_STORAGE_ROOT (Docker volume in compose).
BLUEPRINT_STORAGE_ROOT=/app/storage/blueprints
# Prod escape hatch only while Spaces credentials are blank. Requires
# sitelayer-blueprint-backup.timer or equivalent off-host backup coverage.
ALLOW_LOCAL_BLUEPRINT_STORAGE_IN_PROD=
DO_SPACES_BUCKET=
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=tor1
DO_SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com

# Worker tuning. The worker polls mutation_outbox + sync_events at this
# interval and drains the notifications table in batches.
WORKER_POLL_INTERVAL_MS=10000
NOTIFICATION_BATCH_LIMIT=50
NOTIFICATION_MAX_ATTEMPTS=5
SHUTDOWN_TIMEOUT_MS=15000
