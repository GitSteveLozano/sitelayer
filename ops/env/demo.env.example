# Template for the persistent demo-tier shared env file.
#
# Installed at /app/previews/.env.demo.shared on the sitelayer-preview droplet,
# owner sitelayer:sitelayer, mode 600. NEVER commit a filled-in copy of this
# file to git — it carries real secrets (CLERK_SECRET_KEY, DATABASE_URL, etc.).
#
# Loaded by scripts/deploy-preview.sh when PREVIEW_TIER=demo (which
# scripts/deploy.sh demo sets when it runs deploy-preview.sh on the preview
# droplet — local-fleet, not GitHub Actions). See docs/DEMO_ENVIRONMENT.md.
#
# The demo tier mirrors the dev tier (see ops/env/dev.env.example): a
# long-running named stack on the preview droplet against a dedicated DB. The
# only deltas are the demo tier identity, the sitelayer_demo database, the
# demo.preview.sitelayer.sandolab.xyz host, and Clerk-ON (real sign-in via
# Clerk test-instance sign-in tokens) instead of the act-as RoleSwitcher.

# -----------------------------------------------------------------------------
# Tier identity (load-bearing — packages/config validates these at boot)
# -----------------------------------------------------------------------------
APP_TIER=demo
VITE_APP_TIER=demo
FEATURE_FLAGS=

# -----------------------------------------------------------------------------
# Database — dedicated sitelayer_demo DB on the managed cluster
# -----------------------------------------------------------------------------
# Replace <password> with the demo DB role password. Use a least-privilege role
# (e.g. sitelayer_demo_app) scoped to CONNECT on sitelayer_demo only — it must
# NOT have CONNECT on sitelayer_prod (shared-cluster blast-radius mitigation).
# The connection string MUST point at sitelayer_demo or the APP_TIER=demo guard
# refuses to boot (packages/config/src/index.ts assertDatabaseMatchesTier).
DATABASE_URL=postgres://sitelayer_demo_app:<password>@private-sitelayer-db-do-user-NNNN-0.k.db.ondigitalocean.com:25060/sitelayer_demo?sslmode=require
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Read-only prod replica is intentionally NOT wired for demo. The public demo
# tier must never touch production data.

# -----------------------------------------------------------------------------
# Demo tenant defaults
# -----------------------------------------------------------------------------
ACTIVE_COMPANY_SLUG=la-operations
ACTIVE_USER_ID=demo-user

# -----------------------------------------------------------------------------
# Auth — Clerk-ON via the existing test instance
# -----------------------------------------------------------------------------
# Demo is Clerk-ON: prospects sign in with real Clerk sessions minted by the
# operator as sign-in tokens (POST https://api.clerk.com/v1/sign_in_tokens with
# CLERK_SECRET_KEY -> ?__clerk_ticket= link; see docs/steve-handoff R2). Reuse
# the same Clerk TEST instance (pk_test ...clerk.accounts.dev) that the dev /
# preview tiers use. CLERK_SECRET_KEY is a real secret — supplied at runtime in
# this file by the operator, never committed.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_aW1wcm92ZWQtYmVkYnVnLTMwLmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_JWT_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# SECURITY: the demo tier is a public internet-reachable copy. Require a real
# (shared) Clerk session — do NOT leave the header act-as fallback on, or any
# x-sitelayer-user-id / x-sitelayer-act-as header impersonates anyone and leaks
# data (incl. /api/spec, /api/metrics). Wire the shared Clerk TEST JWT key above
# and keep the fallback OFF. (With a key wired the API also defaults this OFF —
# apps/api/src/auth.ts loadAuthConfig — but set it explicitly here too.) For a
# key-less RBAC demo, front the droplet with Cloudflare Access / an IP allowlist.
AUTH_ALLOW_HEADER_FALLBACK=0

# -----------------------------------------------------------------------------
# Access control (light shared access code)
# -----------------------------------------------------------------------------
# The demo URL resolves publicly via the *.preview.sitelayer.sandolab.xyz
# wildcard. Per the demo-design decision, a light shared access code keeps
# casual crawlers/bots out. This is enforced at the EDGE (Traefik basicAuth or
# Cloudflare Access — see docs/steve-handoff R3/R5), NOT inside this app stack,
# so the compose file stays identical to the dev tier. Set the credential there;
# this var is documented here for the operator's reference only.
# DEMO_ACCESS_CODE=<shared-code>
# Minimum 24h. Used for one-click demo email links minted by
# /api/demo/sign-in-link and scripts/demo-email.ts.
DEMO_SIGN_IN_TOKEN_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# Blueprint storage
# -----------------------------------------------------------------------------
# Recommended: dedicated demo bucket. Create with:
#   doctl spaces create sitelayer-blueprints-demo --region tor1
# and issue a scoped key/secret for it. Leave commented out to fall back to
# the per-stack Docker volume (BLUEPRINT_STORAGE_ROOT).
# DO_SPACES_BUCKET=sitelayer-blueprints-demo
# DO_SPACES_REGION=tor1
# DO_SPACES_KEY=<demo-scoped-key>
# DO_SPACES_SECRET=<demo-scoped-secret>
BLUEPRINT_STORAGE_ROOT=/app/storage/blueprints

# -----------------------------------------------------------------------------
# QBO — sandbox only on demo (never live; demo never pushes to Intuit)
# -----------------------------------------------------------------------------
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox
QBO_STATE_SECRET=
QBO_WEBHOOK_VERIFIER=
QBO_LIVE_RENTAL_INVOICE=0
QBO_LIVE_ESTIMATE_PUSH=0
QBO_LIVE_LABOR_PAYROLL=0

# -----------------------------------------------------------------------------
# Rate limiting (lower than dev — the demo audience is untrusted)
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_IP_PER_MIN=15
RATE_LIMIT_PER_USER_PER_MIN=30

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Sentry is optional on demo; if set, events tag environment=demo (rendered
# from PREVIEW_TIER by scripts/deploy-preview.sh).
SENTRY_DSN=
SENTRY_WORKER_DSN=
VITE_SENTRY_DSN=
DEBUG_TRACE_TOKEN=
NOTIFICATIONS_ENABLED=0
SITELAYER_PUBLIC_BASE=https://demo.preview.sitelayer.sandolab.xyz
DEMO_APP_ORIGIN=https://demo.preview.sitelayer.sandolab.xyz
SITELAYER_WORK_REQUEST_WEBHOOK_TOKEN=
MESH_WORK_REQUEST_DISPATCH_URL=
MESH_WORK_REQUEST_DISPATCH_TOKEN=
AGENT_FEED_TOKENS=
SITELAYER_OPS_DIAGNOSTIC_AGENT_AUDIENCE=
WORK_REQUEST_CALLBACK_TOKEN_TTL_HOURS=72
WORK_REQUEST_REVIEW_STALE_HOURS=48
WORK_REQUEST_AGENT_STALE_HOURS=24
WORK_REQUEST_STALE_SWEEP_INTERVAL_MS=300000
WORK_REQUEST_STALE_SWEEP_LIMIT=25
WORK_REQUEST_CALLBACK_MISSING_HOURS=24
WORK_REQUEST_CALLBACK_RECONCILE_INTERVAL_MS=300000
WORK_REQUEST_CALLBACK_RECONCILE_LIMIT=25

# Usage-capture artifact analysis. Text/json capture artifacts are summarized
# deterministically by default. Raw audio/video analysis stays off in demo
# unless the operator explicitly provisions local media analysis. The preview
# worker runs in Docker, so host.docker.internal routes to the droplet host.
MAX_CAPTURE_ARTIFACT_BYTES=52428800
CAPTURE_ARTIFACT_ANALYSIS_INTERVAL_MS=60000
CAPTURE_ARTIFACT_ANALYSIS_LIMIT=10
CAPTURE_ARTIFACT_ANALYSIS_MAX_BYTES=1048576
CAPTURE_ARTIFACT_AUDIO_ANALYSIS_MODE=off
CAPTURE_ARTIFACT_WHISPER_URL=http://host.docker.internal:5678
CAPTURE_ARTIFACT_WHISPER_PAYLOAD_MODE=base64
CAPTURE_ARTIFACT_WHISPER_TIMEOUT_MS=10000
CAPTURE_ARTIFACT_WHISPER_UNAVAILABLE_POLICY=retry
CAPTURE_ARTIFACT_VIDEO_ANALYSIS_MODE=off

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
# SECURITY: /api/metrics fails closed on every deployed tier — a blank token
# here returns 401 instead of serving the public Prometheus dump. Set a random
# token to scrape from the demo tier; only `local` serves metrics open.
API_METRICS_TOKEN=
INTERNAL_AUTH_TOKEN=
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@demo.preview.sitelayer.sandolab.xyz
BLUEPRINT_VISION_MODE=dry-run
ANTHROPIC_API_KEY=
