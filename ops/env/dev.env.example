# Template for the persistent dev-tier shared env file.
#
# Installed at /app/previews/.env.dev.shared on the sitelayer-preview droplet,
# owner sitelayer:sitelayer, mode 600. NEVER commit a filled-in copy of this
# file to git — it carries real secrets.
#
# Loaded by scripts/deploy-preview.sh when PREVIEW_TIER=dev, which
# scripts/deploy.sh dev sets when invoking it on the preview droplet. See
# docs/DEV_ENVIRONMENT.md.

# -----------------------------------------------------------------------------
# Tier identity (load-bearing — packages/config validates these at boot)
# -----------------------------------------------------------------------------
APP_TIER=dev
VITE_APP_TIER=dev
FEATURE_FLAGS=

# -----------------------------------------------------------------------------
# Database — dedicated sitelayer_dev DB on the managed cluster
# -----------------------------------------------------------------------------
# Replace <password> with the sitelayer_dev_app role password from doctl /
# the cluster admin UI. The connection string MUST point at sitelayer_dev or
# the APP_TIER=dev guard refuses to boot (packages/config/src/index.ts:157).
DATABASE_URL=postgres://sitelayer_dev_app:<password>@private-sitelayer-db-do-user-NNNN-0.k.db.ondigitalocean.com:25060/sitelayer_dev?sslmode=require
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Read-only prod replica is intentionally NOT wired for dev. If a specific
# dev session needs production reads (e.g. agent diagnosing a customer issue),
# the operator sets DATABASE_URL_PROD_RO + FEATURE_FLAGS=read-prod-ro on a
# one-off basis, then unsets when done.

# -----------------------------------------------------------------------------
# Demo tenant defaults
# -----------------------------------------------------------------------------
ACTIVE_COMPANY_SLUG=la-operations
ACTIVE_USER_ID=demo-user

# -----------------------------------------------------------------------------
# Auth — Clerk test pool (same publishable key the preview tier uses)
# -----------------------------------------------------------------------------
# Leaving CLERK_JWT_KEY blank keeps the dev role-switcher panel active so
# agents can exercise RBAC without provisioning Clerk users.
CLERK_JWT_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
VITE_CLERK_PUBLISHABLE_KEY=pk_test_aW1wcm92ZWQtYmVkYnVnLTMwLmNsZXJrLmFjY291bnRzLmRldiQ
AUTH_ALLOW_HEADER_FALLBACK=1

# -----------------------------------------------------------------------------
# Blueprint storage
# -----------------------------------------------------------------------------
# Recommended: dedicated dev bucket. Create with:
#   doctl spaces create sitelayer-blueprints-dev --region tor1
# and issue a scoped key/secret for it. Leave commented out to fall back to
# the per-stack Docker volume (BLUEPRINT_STORAGE_ROOT).
# DO_SPACES_BUCKET=sitelayer-blueprints-dev
# DO_SPACES_REGION=tor1
# DO_SPACES_KEY=<dev-scoped-key>
# DO_SPACES_SECRET=<dev-scoped-secret>
BLUEPRINT_STORAGE_ROOT=/app/storage/blueprints

# -----------------------------------------------------------------------------
# QBO — sandbox only on dev
# -----------------------------------------------------------------------------
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox
QBO_STATE_SECRET=
QBO_WEBHOOK_VERIFIER=
QBO_LIVE_RENTAL_INVOICE=0
QBO_LIVE_ESTIMATE_PUSH=0
QBO_LIVE_LABOR_PAYROLL=0

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Sentry is optional on dev; if set, events will tag environment=dev (rendered
# from PREVIEW_TIER by scripts/deploy-preview.sh).
SENTRY_DSN=
SENTRY_WORKER_DSN=
VITE_SENTRY_DSN=
DEBUG_TRACE_TOKEN=
NOTIFICATIONS_ENABLED=0
# Legacy fallback for pre-scoped Work Request callback rows. New Mesh dispatches
# carry a per-dispatch scoped callback token in the outbox payload.
SITELAYER_PUBLIC_BASE=https://dev.sitelayer.sandolab.xyz
SITELAYER_WORK_REQUEST_WEBHOOK_TOKEN=
MESH_WORK_REQUEST_DISPATCH_URL=
MESH_WORK_REQUEST_DISPATCH_TOKEN=
WORK_REQUEST_CALLBACK_TOKEN_TTL_HOURS=72
WORK_REQUEST_REVIEW_STALE_HOURS=48
WORK_REQUEST_AGENT_STALE_HOURS=24
WORK_REQUEST_STALE_SWEEP_INTERVAL_MS=300000
WORK_REQUEST_STALE_SWEEP_LIMIT=25
WORK_REQUEST_CALLBACK_MISSING_HOURS=24
WORK_REQUEST_CALLBACK_RECONCILE_INTERVAL_MS=300000
WORK_REQUEST_CALLBACK_RECONCILE_LIMIT=25

# Usage-capture artifact analysis. Text/json capture artifacts are summarized
# deterministically by default. Raw audio analysis uses a Whisper-compatible
# /transcribe endpoint by default; video analysis is still opt-in. The default
# payload mode uploads base64 bytes so Docker workers do not need a shared
# filesystem with the Whisper server.
MAX_CAPTURE_ARTIFACT_BYTES=52428800
CAPTURE_ARTIFACT_ANALYSIS_INTERVAL_MS=60000
CAPTURE_ARTIFACT_ANALYSIS_LIMIT=10
CAPTURE_ARTIFACT_ANALYSIS_MAX_BYTES=1048576
CAPTURE_ARTIFACT_AUDIO_ANALYSIS_MODE=local-whisper
CAPTURE_ARTIFACT_WHISPER_URL=http://host.docker.internal:5678
CAPTURE_ARTIFACT_WHISPER_PAYLOAD_MODE=base64
CAPTURE_ARTIFACT_WHISPER_TIMEOUT_MS=10000
CAPTURE_ARTIFACT_VIDEO_ANALYSIS_MODE=off

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
API_METRICS_TOKEN=
INTERNAL_AUTH_TOKEN=
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@dev.sitelayer.sandolab.xyz
BLUEPRINT_VISION_MODE=dry-run
ANTHROPIC_API_KEY=
