# Optional BUILD-time vars for scripts/deploy-production-local.sh.
# Copy to ops/env/production.build.env (gitignored) on the fleet build box.
# All have safe public defaults in the script — only set what you want to override.
#
# Web Sentry (browser error tracking). Leave unset to ship with web Sentry idle.
# VITE_SENTRY_DSN=
#
# Sentry sourcemap upload token (server-side, secret). Leave unset to skip
# sourcemap upload entirely (the Dockerfile only uploads when this is present).
# SENTRY_AUTH_TOKEN=
#
# Public defaults already baked into the deploy script (override only if they change):
# VITE_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsuc2FuZG9sYWIueHl6JA
# VITE_APP_TIER=prod
# VITE_COMPANY_SLUG=la-operations
# SENTRY_ORG=sandolabs
# SENTRY_WEB_PROJECT=sitelayer-web
