{
  "version": 1,
  "environment": "production",
  "renderedPath": "/app/sitelayer/.env",
  "enforceVariable": "PRODUCTION_ENV_RENDER_ENFORCE",
  "sentinels": ["", "127.0.0.1", "localhost", "unknown", "PLACEHOLDER", "CHANGEME"],
  "entries": [
    {
      "name": "APP_IMAGE",
      "source": "generated",
      "scope": "runtime",
      "required": true,
      "description": "Immutable container image built by the production deploy workflow."
    },
    {
      "name": "APP_TIER",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "prod",
      "description": "Runtime tier; prod enables tier-isolation and production auth checks."
    },
    {
      "name": "NODE_ENV",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "production",
      "description": "Node runtime mode."
    },
    {
      "name": "FEATURE_FLAGS",
      "source": "variable",
      "scope": "runtime",
      "required": false,
      "description": "Comma-separated production feature flags."
    },
    {
      "name": "DATABASE_URL",
      "source": "secret",
      "scope": "runtime",
      "required": true,
      "description": "Production Postgres app-role connection string."
    },
    {
      "name": "DATABASE_URL_PROD_RO",
      "source": "secret",
      "scope": "runtime",
      "required": false,
      "description": "Optional read-only production pool for explicit read-prod-ro workflows."
    },
    {
      "name": "DATABASE_SSL_REJECT_UNAUTHORIZED",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "false",
      "description": "DigitalOcean managed Postgres TLS mode until a CA bundle is configured."
    },
    {
      "name": "ACTIVE_COMPANY_SLUG",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "la-operations",
      "description": "Fallback company slug for legacy/demo paths."
    },
    {
      "name": "ACTIVE_USER_ID",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "demo-user",
      "description": "Fallback user id for legacy/demo paths."
    },
    {
      "name": "ALLOWED_ORIGINS",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "description": "Comma-separated CORS allowlist; production must not include localhost."
    },
    {
      "name": "QBO_CLIENT_ID",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "sentinels": ["demo"],
      "description": "Intuit QuickBooks Online OAuth client id."
    },
    {
      "name": "QBO_CLIENT_SECRET",
      "source": "secret",
      "scope": "runtime",
      "required": true,
      "sentinels": ["demo"],
      "description": "Intuit QuickBooks Online OAuth client secret."
    },
    {
      "name": "QBO_REDIRECT_URI",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "https://sitelayer.sandolab.xyz/api/integrations/qbo/callback",
      "description": "Public Intuit OAuth callback URL."
    },
    {
      "name": "QBO_SUCCESS_REDIRECT_URI",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "https://sitelayer.sandolab.xyz/?qbo=connected",
      "description": "Public UI redirect after a successful QBO connection."
    },
    {
      "name": "QBO_ENVIRONMENT",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "sandbox",
      "description": "QBO API environment: sandbox or production."
    },
    {
      "name": "QBO_STATE_SECRET",
      "source": "secret",
      "scope": "runtime",
      "required": true,
      "sentinels": ["demo-qbo-state-secret"],
      "description": "HMAC secret for QBO OAuth state."
    },
    {
      "name": "QBO_WEBHOOK_VERIFIER",
      "source": "secret",
      "scope": "runtime",
      "required": false,
      "description": "Intuit webhook verifier token."
    },
    {
      "name": "CLERK_SECRET_KEY",
      "source": "secret",
      "scope": "runtime",
      "required": false,
      "description": "Reserved for Clerk Backend API calls."
    },
    {
      "name": "CLERK_JWT_KEY",
      "source": "secret",
      "scope": "runtime",
      "required": true,
      "multiline": true,
      "description": "Clerk JWT public key used by API auth verification."
    },
    {
      "name": "CLERK_ISSUER",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "description": "Expected Clerk issuer."
    },
    {
      "name": "CLERK_WEBHOOK_SECRET",
      "source": "secret",
      "scope": "runtime",
      "required": true,
      "description": "Svix webhook signing secret for Clerk events."
    },
    {
      "name": "INTERNAL_AUTH_TOKEN",
      "source": "secret",
      "scope": "runtime",
      "required": false,
      "description": "Internal service bearer token."
    },
    {
      "name": "AUTH_ALLOW_HEADER_FALLBACK",
      "source": "variable",
      "scope": "runtime",
      "required": false,
      "description": "Legacy header-auth fallback flag; leave unset/false in production."
    },
    {
      "name": "AUTH_ALLOW_HEADER_FALLBACK_BREAK_GLASS",
      "source": "variable",
      "scope": "runtime",
      "required": false,
      "description": "Explicit break-glass unlock for production header fallback."
    },
    {
      "name": "DO_SPACES_KEY",
      "source": "secret",
      "scope": "runtime",
      "required": true,
      "description": "Scoped DigitalOcean Spaces access key."
    },
    {
      "name": "DO_SPACES_SECRET",
      "source": "secret",
      "scope": "runtime",
      "required": true,
      "description": "Scoped DigitalOcean Spaces secret key."
    },
    {
      "name": "DO_SPACES_REGION",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "tor1",
      "description": "DigitalOcean Spaces region."
    },
    {
      "name": "DO_SPACES_ENDPOINT",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "https://tor1.digitaloceanspaces.com",
      "description": "DigitalOcean Spaces endpoint."
    },
    {
      "name": "DO_SPACES_BUCKET",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "sitelayer-blueprints-prod",
      "description": "Production blueprint storage bucket."
    },
    {
      "name": "ALLOW_LOCAL_BLUEPRINT_STORAGE_IN_PROD",
      "source": "variable",
      "scope": "runtime",
      "required": false,
      "description": "Emergency-only local blueprint storage fallback flag."
    },
    {
      "name": "BLUEPRINT_STORAGE_ROOT",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "/app/storage/blueprints",
      "description": "Local blueprint storage path used by dev/preview/fallback mode."
    },
    {
      "name": "SENTRY_DSN",
      "source": "secret",
      "scope": "runtime",
      "required": true,
      "description": "API Sentry DSN."
    },
    {
      "name": "SENTRY_WORKER_DSN",
      "source": "secret",
      "scope": "runtime",
      "required": false,
      "description": "Optional worker-specific Sentry DSN."
    },
    {
      "name": "SENTRY_ENVIRONMENT",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "production",
      "description": "Sentry environment label."
    },
    {
      "name": "SENTRY_TRACES_SAMPLE_RATE",
      "source": "variable",
      "scope": "runtime",
      "required": true,
      "default": "0.1",
      "description": "API/worker trace sample rate."
    },
    {
      "name": "SENTRY_ORG",
      "source": "variable",
      "scope": "runtime",
      "required": false,
      "default": "sandolabs",
      "description": "Sentry organization slug for debug trace lookups."
    },
    {
      "name": "SENTRY_AUTH_TOKEN",
      "source": "secret",
      "scope": "runtime",
      "required": false,
      "description": "Sentry auth token, only needed when production debug trace lookup is enabled."
    },
    {
      "name": "DEBUG_TRACE_TOKEN",
      "source": "secret",
      "scope": "runtime",
      "required": false,
      "description": "Bearer token for production debug trace lookup."
    },
    {
      "name": "DEBUG_ALLOW_PROD",
      "source": "variable",
      "scope": "runtime",
      "required": false,
      "description": "Break-glass flag for production debug endpoints."
    },
    {
      "name": "API_METRICS_TOKEN",
      "source": "secret",
      "scope": "runtime",
      "required": true,
      "description": "Bearer token for production /api/metrics."
    },
    {
      "name": "EMAIL_PROVIDER",
      "source": "variable",
      "scope": "runtime",
      "required": false,
      "default": "console",
      "description": "Outbound email provider."
    },
    {
      "name": "EMAIL_FROM",
      "source": "variable",
      "scope": "runtime",
      "required": false,
      "default": "noreply@sitelayer.sandolab.xyz",
      "description": "Default outbound email sender."
    },
    {
      "name": "RESEND_API_KEY",
      "source": "secret",
      "scope": "runtime",
      "required": false,
      "description": "Resend API key when EMAIL_PROVIDER=resend."
    },
    {
      "name": "SENDGRID_API_KEY",
      "source": "secret",
      "scope": "runtime",
      "required": false,
      "description": "SendGrid API key when EMAIL_PROVIDER=sendgrid."
    },
    {
      "name": "SHUTDOWN_TIMEOUT_MS",
      "source": "variable",
      "scope": "runtime",
      "required": false,
      "default": "15000",
      "description": "Graceful shutdown timeout."
    },
    {
      "name": "SITELAYER_ENV_ENFORCE",
      "source": "variable",
      "scope": "runtime",
      "required": false,
      "description": "Phase-2 API env validator toggle. Leave unset until production warnings are clean."
    },
    {
      "name": "VITE_API_URL",
      "source": "variable",
      "scope": "build",
      "required": false,
      "description": "Build-time SPA API base URL. Blank means same-origin."
    },
    {
      "name": "VITE_CLERK_PUBLISHABLE_KEY",
      "source": "variable",
      "scope": "build",
      "required": true,
      "description": "Build-time public Clerk publishable key."
    },
    {
      "name": "VITE_COMPANY_SLUG",
      "source": "variable",
      "scope": "build",
      "required": false,
      "default": "la-operations",
      "description": "Build-time fallback company slug."
    },
    {
      "name": "VITE_USER_ID",
      "source": "variable",
      "scope": "build",
      "required": false,
      "default": "demo-user",
      "description": "Build-time fallback user id."
    },
    {
      "name": "VITE_APP_TIER",
      "source": "variable",
      "scope": "build",
      "required": true,
      "default": "prod",
      "description": "Build-time tier ribbon/config."
    },
    {
      "name": "VITE_SENTRY_DSN",
      "source": "secret",
      "scope": "build",
      "required": false,
      "description": "Build-time web Sentry DSN."
    },
    {
      "name": "VITE_SENTRY_ENVIRONMENT",
      "source": "variable",
      "scope": "build",
      "required": false,
      "default": "production",
      "description": "Build-time web Sentry environment label."
    },
    {
      "name": "VITE_SENTRY_TRACES_SAMPLE_RATE",
      "source": "variable",
      "scope": "build",
      "required": false,
      "default": "0.1",
      "description": "Build-time web trace sample rate."
    },
    {
      "name": "VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE",
      "source": "variable",
      "scope": "build",
      "required": false,
      "default": "0.1",
      "description": "Build-time web session replay sample rate."
    },
    {
      "name": "VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE",
      "source": "variable",
      "scope": "build",
      "required": false,
      "default": "1.0",
      "description": "Build-time web on-error replay sample rate."
    },
    {
      "name": "SENTRY_WEB_PROJECT",
      "source": "variable",
      "scope": "build",
      "required": false,
      "default": "sitelayer-web",
      "description": "Sentry web project slug for source map uploads."
    }
  ]
}
