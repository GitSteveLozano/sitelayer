{
  "name": "@sitelayer/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck",
    "format": "npm run typecheck",
    "test": "vitest run",
    "test:integration": "RUN_API_INTEGRATION=1 vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.645.0",
    "@sentry/node": "^10.50.0",
    "@sitelayer/domain": "file:../../packages/domain",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  }
}
