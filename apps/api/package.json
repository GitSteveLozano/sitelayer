{
  "name": "@sitelayer/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck",
    "format": "npm run typecheck",
    "test": "vitest run",
    "test:integration": "RUN_API_INTEGRATION=1 vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/lib-storage": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@sentry/node": "^10.51.0",
    "@sitelayer/config": "file:../../packages/config",
    "@sitelayer/domain": "file:../../packages/domain",
    "@sitelayer/logger": "file:../../packages/logger",
    "@sitelayer/queue": "file:../../packages/queue",
    "@sitelayer/workflows": "file:../../packages/workflows",
    "@types/pdfkit": "^0.17.6",
    "busboy": "^1.6.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "svix": "1.92.2"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/pg": "^8.11.11",
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  }
}
