{
  "name": "@sitelayer/scenario",
  "version": "0.0.0",
  "description": "Scenario engine: Zod-validated scenario docs → deterministic apply plan, replayed through @sitelayer/workflows reducers.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
