{
  "name": "@sitelayer/capture-schema",
  "version": "0.0.0",
  "description": "Shared TakeoffResult and PricedEstimate schemas. Source of truth.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./takeoff": {
      "types": "./dist/takeoff.d.ts",
      "default": "./dist/takeoff.js"
    },
    "./pricing": {
      "types": "./dist/pricing.d.ts",
      "default": "./dist/pricing.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "default": "./dist/validate.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "private": true
}
