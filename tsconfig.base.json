{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./apps/web/src/*"],
      "@sitelayer/config": ["./packages/config/src/index.ts"],
      "@sitelayer/domain": ["./packages/domain/src/index.ts"],
      "@sitelayer/logger": ["./packages/logger/src/index.ts"],
      "@sitelayer/queue": ["./packages/queue/src/index.ts"],
      "@sitelayer/workflows": ["./packages/workflows/src/index.ts"],
      "@sitelayer/scenario": ["./packages/scenario/src/index.ts"],
      "@sitelayer/capture-schema": ["./packages/capture-schema/src/index.ts"],
      "@sitelayer/capture-schema/*": ["./packages/capture-schema/src/*"],
      "@sitelayer/capture-catalog": ["./packages/capture-catalog/src/index.ts"],
      "@sitelayer/formula-evaluator": ["./packages/formula-evaluator/src/index.ts"],
      "@sitelayer/pipe-blueprint": ["./packages/pipe-blueprint/src/index.ts"],
      "@sitelayer/pipe-roomplan": ["./packages/pipe-roomplan/src/index.ts"],
      "@sitelayer/pipe-photogrammetry": ["./packages/pipe-photogrammetry/src/index.ts"],
      "@sitelayer/pipe-drone": ["./packages/pipe-drone/src/index.ts"]
    }
  }
}
