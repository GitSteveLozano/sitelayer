{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@sitelayer/config": ["packages/config/src/index.ts"],
      "@sitelayer/domain": ["packages/domain/src/index.ts"],
      "@sitelayer/logger": ["packages/logger/src/index.ts"],
      "@sitelayer/queue": ["packages/queue/src/index.ts"]
    }
  }
}
